{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["standard", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    // --- Possible Errors ---
    "no-debugger": "error",
    "no-duplicate-imports": "error",
    "no-promise-executor-return": "error",
    "no-template-curly-in-string": "error",
    "no-unreachable-loop": "error",
 
    // --- Best Practices ---
    "curly": ["error", "all"],
    "default-case": "error",
    "default-case-last": "error",
    "eqeqeq": ["error", "always"],
    "no-else-return": ["error", { "allowElseIf": false }],
    "no-empty-function": "warn",
    "no-eval": "error",
    "no-extend-native": "error",
    "no-floating-decimal": "error",
    "no-implicit-coercion": "error",
    "no-lone-blocks": "error",
    "no-multi-str": "error",
    "no-param-reassign": ["warn", { "props": false }],
    "no-return-assign": "error",
    "no-self-compare": "error",
    "no-throw-literal": "error",
    "no-useless-concat": "error",
    "no-useless-return": "error",
    "no-var": "error",
    "prefer-const": ["error", { "destructuring": "all" }],
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "prefer-template": "error",
    "require-await": "warn",
    "yoda": "error",
 
    // --- Prettier overrides (formatting owned by Prettier, not ESLint) ---
    // These match your .prettierrc.json and are turned off to avoid conflicts
    "quotes": "off",          // singleQuote: true
    "semi": "off",            // semi: true
    "indent": "off",          // tabWidth: 4
    "comma-dangle": "off",    // trailingComma: "es5"
 
    // --- Style (non-formatting — leave formatting to Prettier) ---
    "camelcase": ["error", { "properties": "never" }],
    "new-cap": ["error", { "newIsCap": true, "capIsNew": false }],
    "no-array-constructor": "error",
    "no-lonely-if": "error",
    "no-nested-ternary": "warn",
    "no-unneeded-ternary": "error",
    "prefer-exponentiation-operator": "error",
    "spaced-comment": ["error", "always", { "markers": ["/"] }],
 
    // --- ES6+ ---
    "no-useless-computed-key": "error",
    "no-useless-constructor": "error",
    "no-useless-rename": "error",
    "object-shorthand": ["error", "always"],
    "prefer-arrow-callback": "error",
    "prefer-destructuring": [
      "warn",
      {
        "array": false,
        "object": true
      }
    ],
    "symbol-description": "error"
  }
}